<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/iiot-pmo#"
     xml:base="https://w3id.org/iiot-pmo"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:iiot-pmo="https://w3id.org/iiot-pmo#">
    <owl:Ontology rdf:about="https://w3id.org/iiot-pmo">
        <owl:versionIRI rdf:resource="https://w3id.org/iiot-pmo/0.2.0"/>
        <terms:description xml:lang="en">Version 0.2.0 extends the initial predictive maintenance ontology with LLM-assisted ontology population, maintenance history, time-series batches, and machine-learning-based predicted failures.</terms:description>
        <terms:references rdf:resource="https://doi.org/10.1002/cpe.7420"/>
        <terms:references rdf:resource="https://doi.org/10.1007/978-3-031-47240-4_22"/>
        <terms:references rdf:resource="https://doi.org/10.1016/j.knosys.2024.112940"/>
        <terms:title xml:lang="en">Industrial IoT &amp; Predictive Maintenance Ontology (IIoT-PMO)</terms:title>
        <rdfs:comment xml:lang="en">Developed according to a METHONTOLOGY-inspired lifecycle: specification, conceptualization, formalization, implementation, and evaluation.</rdfs:comment>
        <owl:versionInfo>0.2.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/references -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/references"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/ns/ssn/detects -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/ssn/detects"/>
    


    <!-- https://w3id.org/iiot-pmo#containsObservation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/iiot-pmo#containsObservation">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#TimeSeriesBatch"/>
        <rdfs:range rdf:resource="https://w3id.org/iiot-pmo#Observation"/>
        <rdfs:comment xml:lang="en">Connects a time-series batch to the observations included in its prediction window.</rdfs:comment>
        <rdfs:label xml:lang="en">contains observation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/iiot-pmo#derivedFromBatch -->


    <owl:ObjectProperty rdf:about="https://w3id.org/iiot-pmo#derivedFromBatch">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#PredictedFailure"/>
        <rdfs:range rdf:resource="https://w3id.org/iiot-pmo#TimeSeriesBatch"/>
        <rdfs:comment xml:lang="en">Links a predicted failure to the time-series batch used as model input.</rdfs:comment>
        <rdfs:label xml:lang="en">derived from batch</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/iiot-pmo#extractsCandidateFor -->


    <owl:ObjectProperty rdf:about="https://w3id.org/iiot-pmo#extractsCandidateFor">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#LLMExtractionTask"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">Links an LLM extraction task to an ontology individual proposed during population.</rdfs:comment>
        <rdfs:label xml:lang="en">extracts candidate for</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/iiot-pmo#generatesAlert -->


    <owl:ObjectProperty rdf:about="https://w3id.org/iiot-pmo#generatesAlert">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#Observation"/>
        <rdfs:range rdf:resource="https://w3id.org/iiot-pmo#Alert"/>
        <rdfs:comment xml:lang="en">Indicates that an observation generated an alert.</rdfs:comment>
        <rdfs:label xml:lang="en">generates alert</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasMaintenanceEvent -->


    <owl:ObjectProperty rdf:about="https://w3id.org/iiot-pmo#hasMaintenanceEvent">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#Equipment"/>
        <rdfs:range rdf:resource="https://w3id.org/iiot-pmo#MaintenanceEvent"/>
        <rdfs:comment xml:lang="en">Associates equipment with a maintenance action or inspection.</rdfs:comment>
        <rdfs:label xml:lang="en">has maintenance event</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasMaintenanceHistory -->


    <owl:ObjectProperty rdf:about="https://w3id.org/iiot-pmo#hasMaintenanceHistory">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/iiot-pmo#hasMaintenanceEvent"/>
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#Equipment"/>
        <rdfs:range rdf:resource="https://w3id.org/iiot-pmo#MaintenanceLog"/>
        <rdfs:comment xml:lang="en">Associates equipment with historical maintenance logs.</rdfs:comment>
        <rdfs:label xml:lang="en">has maintenance history</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasMeasurement -->


    <owl:ObjectProperty rdf:about="https://w3id.org/iiot-pmo#hasMeasurement">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#Observation"/>
        <rdfs:range rdf:resource="https://w3id.org/iiot-pmo#Measurement"/>
        <rdfs:comment xml:lang="en">Connects an observation to its measurement value object.</rdfs:comment>
        <rdfs:comment xml:lang="en">Links an observation to its result, equivalent to sosa:hasResult.</rdfs:comment>
        <rdfs:label xml:lang="en">has measurement</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasObservation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/iiot-pmo#hasObservation">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#Sensor"/>
        <rdfs:range rdf:resource="https://w3id.org/iiot-pmo#Observation"/>
        <rdfs:comment xml:lang="en">Links a sensor to an observation it produced.</rdfs:comment>
        <rdfs:comment xml:lang="en">Links a sensor to the observations it has made, equivalent to ssn:madeObservation.</rdfs:comment>
        <rdfs:label xml:lang="en">has observation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasPredictedFailure -->


    <owl:ObjectProperty rdf:about="https://w3id.org/iiot-pmo#hasPredictedFailure">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#Equipment"/>
        <rdfs:range rdf:resource="https://w3id.org/iiot-pmo#PredictedFailure"/>
        <rdfs:comment xml:lang="en">Links equipment to a failure prediction generated from sensor or maintenance evidence.</rdfs:comment>
        <rdfs:label xml:lang="en">has predicted failure</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasSensor -->


    <owl:ObjectProperty rdf:about="https://w3id.org/iiot-pmo#hasSensor">
        <owl:inverseOf rdf:resource="https://w3id.org/iiot-pmo#monitors"/>
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#Equipment"/>
        <rdfs:range rdf:resource="https://w3id.org/iiot-pmo#Sensor"/>
        <rdfs:comment xml:lang="en">Connects equipment to an installed or associated sensor.</rdfs:comment>
        <rdfs:label xml:lang="en">has sensor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/iiot-pmo#indicatesFailureMode -->


    <owl:ObjectProperty rdf:about="https://w3id.org/iiot-pmo#indicatesFailureMode">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/iiot-pmo#Alert"/>
                    <rdf:Description rdf:about="https://w3id.org/iiot-pmo#PredictedFailure"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/iiot-pmo#FailureMode"/>
        <rdfs:comment xml:lang="en">Links an alert or predicted failure to a suspected or known failure mode.</rdfs:comment>
        <rdfs:label xml:lang="en">indicates failure mode</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/iiot-pmo#monitors -->


    <owl:ObjectProperty rdf:about="https://w3id.org/iiot-pmo#monitors">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/ssn/detects"/>
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#Sensor"/>
        <rdfs:range rdf:resource="https://w3id.org/iiot-pmo#Equipment"/>
        <rdfs:comment xml:lang="en">Indicates which equipment is monitored by a sensor.</rdfs:comment>
        <rdfs:comment xml:lang="en">iiot:monitors is a domain-specific specialization of ssn:detects, linking a sensor to the equipment it monitors.</rdfs:comment>
        <rdfs:label xml:lang="en">monitors</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/iiot-pmo#predictedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/iiot-pmo#predictedBy">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#PredictedFailure"/>
        <rdfs:range rdf:resource="https://w3id.org/iiot-pmo#MLModel"/>
        <rdfs:comment xml:lang="en">Links a predicted failure to the machine learning model that produced it.</rdfs:comment>
        <rdfs:label xml:lang="en">predicted by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/iiot-pmo#usesDataSource -->


    <owl:ObjectProperty rdf:about="https://w3id.org/iiot-pmo#usesDataSource">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#LLMExtractionTask"/>
        <rdfs:range rdf:resource="https://w3id.org/iiot-pmo#DataSource"/>
        <rdfs:comment xml:lang="en">Links an LLM extraction task to its source data.</rdfs:comment>
        <rdfs:label xml:lang="en">uses data source</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/iiot-pmo#hasBatchWindowEnd -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/iiot-pmo#hasBatchWindowEnd">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#TimeSeriesBatch"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">End timestamp of the time-series window.</rdfs:comment>
        <rdfs:label xml:lang="en">has batch window end</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasBatchWindowStart -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/iiot-pmo#hasBatchWindowStart">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#TimeSeriesBatch"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Start timestamp of the time-series window.</rdfs:comment>
        <rdfs:label xml:lang="en">has batch window start</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasConfidence -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/iiot-pmo#hasConfidence">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#LLMExtractionTask"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">Confidence assigned to an LLM extraction result.</rdfs:comment>
        <rdfs:label xml:lang="en">has confidence</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasFailureProbability -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/iiot-pmo#hasFailureProbability">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#PredictedFailure"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">Probability assigned by a machine learning model to a predicted failure.</rdfs:comment>
        <rdfs:label xml:lang="en">has failure probability</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasLogText -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/iiot-pmo#hasLogText">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#MaintenanceLog"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Raw or normalized text of a maintenance log.</rdfs:comment>
        <rdfs:label xml:lang="en">has log text</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasMaintenanceAction -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/iiot-pmo#hasMaintenanceAction">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#MaintenanceLog"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Maintenance action described by a maintenance log.</rdfs:comment>
        <rdfs:label xml:lang="en">has maintenance action</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasModelName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/iiot-pmo#hasModelName">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#MLModel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Human-readable model name.</rdfs:comment>
        <rdfs:label xml:lang="en">has model name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasOperatingHours -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/iiot-pmo#hasOperatingHours">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#Equipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">Operating hours accumulated by an equipment asset.</rdfs:comment>
        <rdfs:label xml:lang="en">has operating hours</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasPredictionHorizonHours -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/iiot-pmo#hasPredictionHorizonHours">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#PredictedFailure"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">Future time horizon, in hours, covered by a predicted failure.</rdfs:comment>
        <rdfs:label xml:lang="en">has prediction horizon hours</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasThreshold -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/iiot-pmo#hasThreshold">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">Configured threshold value for a sensor.</rdfs:comment>
        <rdfs:label xml:lang="en">has threshold</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasTimestamp -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/iiot-pmo#hasTimestamp">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Time associated with an observation, alert, prediction, or maintenance event.</rdfs:comment>
        <rdfs:label xml:lang="en">has timestamp</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasUnit -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/iiot-pmo#hasUnit">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#Measurement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unit used for the measurement value.</rdfs:comment>
        <rdfs:label xml:lang="en">has unit</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/iiot-pmo#hasValue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/iiot-pmo#hasValue">
        <rdfs:domain rdf:resource="https://w3id.org/iiot-pmo#Measurement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">Numeric value of a measurement.</rdfs:comment>
        <rdfs:label xml:lang="en">has value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/ns/sosa/FeatureOfInterest -->


    <owl:Class rdf:about="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
    


    <!-- http://www.w3.org/ns/sosa/Observation -->


    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Observation">
        <owl:equivalentClass rdf:resource="https://w3id.org/iiot-pmo#Observation"/>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/Result -->


    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Result"/>
    


    <!-- http://www.w3.org/ns/sosa/Sensor -->


    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Sensor">
        <owl:equivalentClass rdf:resource="https://w3id.org/iiot-pmo#Sensor"/>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/ssn/System -->


    <owl:Class rdf:about="http://www.w3.org/ns/ssn/System"/>
    


    <!-- https://w3id.org/iiot-pmo#Alert -->


    <owl:Class rdf:about="https://w3id.org/iiot-pmo#Alert">
        <rdfs:comment xml:lang="en">A semantic notification generated when an observation indicates abnormal or risky operating behavior.</rdfs:comment>
        <rdfs:label xml:lang="en">Alert</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/iiot-pmo#Asset -->


    <owl:Class rdf:about="https://w3id.org/iiot-pmo#Asset">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
        <rdfs:comment xml:lang="en">A physical or logical industrial entity that can be monitored, maintained, or identified in a factory knowledge graph.</rdfs:comment>
        <rdfs:comment xml:lang="en">An industrial asset represents the physical or logical entity whose properties (e.g. temperature, vibration) are observed, making it a subclass of sosa:FeatureOfInterest.</rdfs:comment>
        <rdfs:label xml:lang="en">Asset</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/iiot-pmo#CriticalAlert -->


    <owl:Class rdf:about="https://w3id.org/iiot-pmo#CriticalAlert">
        <rdfs:subClassOf rdf:resource="https://w3id.org/iiot-pmo#ThresholdAlert"/>
        <rdfs:comment xml:lang="en">A threshold alert representing a critical operating condition.</rdfs:comment>
        <rdfs:label xml:lang="en">Critical Alert</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/iiot-pmo#DataSource -->


    <owl:Class rdf:about="https://w3id.org/iiot-pmo#DataSource">
        <rdfs:comment xml:lang="en">A structured, semi-structured, or unstructured source used to populate the ontology.</rdfs:comment>
        <rdfs:label xml:lang="en">Data Source</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/iiot-pmo#Equipment -->


    <owl:Class rdf:about="https://w3id.org/iiot-pmo#Equipment">
        <rdfs:subClassOf rdf:resource="https://w3id.org/iiot-pmo#Asset"/>
        <rdfs:comment xml:lang="en">Industrial machinery that performs a production, utility, or support function.</rdfs:comment>
        <rdfs:label xml:lang="en">Equipment</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/iiot-pmo#FailureMode -->


    <owl:Class rdf:about="https://w3id.org/iiot-pmo#FailureMode">
        <rdfs:comment xml:lang="en">A potential or observed mechanism of equipment degradation or failure.</rdfs:comment>
        <rdfs:label xml:lang="en">Failure Mode</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/iiot-pmo#GRURNNModel -->


    <owl:Class rdf:about="https://w3id.org/iiot-pmo#GRURNNModel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/iiot-pmo#MLModel"/>
        <rdfs:comment xml:lang="en">A recurrent neural network model based on gated recurrent units for time-series failure prediction.</rdfs:comment>
        <rdfs:label xml:lang="en">GRU-RNN Model</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/iiot-pmo#LLMExtractionTask -->


    <owl:Class rdf:about="https://w3id.org/iiot-pmo#LLMExtractionTask">
        <rdfs:comment xml:lang="en">A data ingestion task in which a large language model extracts ontology candidates from unstructured industrial text.</rdfs:comment>
        <rdfs:label xml:lang="en">LLM Extraction Task</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/iiot-pmo#MLModel -->


    <owl:Class rdf:about="https://w3id.org/iiot-pmo#MLModel">
        <rdfs:comment xml:lang="en">A computational model that produces predictions from industrial sensor or maintenance data.</rdfs:comment>
        <rdfs:label xml:lang="en">Machine Learning Model</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/iiot-pmo#MaintenanceEvent -->


    <owl:Class rdf:about="https://w3id.org/iiot-pmo#MaintenanceEvent">
        <rdfs:comment xml:lang="en">A maintenance action or inspection event associated with equipment.</rdfs:comment>
        <rdfs:label xml:lang="en">Maintenance Event</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/iiot-pmo#MaintenanceLog -->


    <owl:Class rdf:about="https://w3id.org/iiot-pmo#MaintenanceLog">
        <rdfs:subClassOf rdf:resource="https://w3id.org/iiot-pmo#MaintenanceEvent"/>
        <rdfs:comment xml:lang="en">A textual or semi-structured record describing maintenance actions, operator notes, inspection outcomes, or service events.</rdfs:comment>
        <rdfs:label xml:lang="en">Maintenance Log</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/iiot-pmo#Measurement -->


    <owl:Class rdf:about="https://w3id.org/iiot-pmo#Measurement">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Result"/>
        <rdfs:comment xml:lang="en">A structured representation of a value produced through an observation.</rdfs:comment>
        <rdfs:comment xml:lang="en">iiot:Measurement represents the structured value or representation of the observation result, aligning it as a subclass of sosa:Result.</rdfs:comment>
        <rdfs:label xml:lang="en">Measurement</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/iiot-pmo#MeasurementValue -->


    <owl:Class rdf:about="https://w3id.org/iiot-pmo#MeasurementValue">
        <rdfs:subClassOf rdf:resource="https://w3id.org/iiot-pmo#Measurement"/>
        <rdfs:comment xml:lang="en">A concrete numeric measurement value mapped from a source column such as temp_c, vibration_mm_s, or pressure_bar.</rdfs:comment>
        <rdfs:label xml:lang="en">Measurement Value</rdfs:label>
