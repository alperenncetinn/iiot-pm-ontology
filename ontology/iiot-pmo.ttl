@prefix iiot: <https://w3id.org/iiot-pmo#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://w3id.org/iiot-pmo>
    a owl:Ontology ;
    dcterms:title "Industrial IoT & Predictive Maintenance Ontology (IIoT-PMO)"@en ;
    dcterms:description "An initial ontology for representing industrial equipment, sensors, observations, measurements, alerts, and failure modes in predictive maintenance scenarios."@en ;
    owl:versionInfo "0.1.0" ;
    rdfs:comment "Designed as a semester project foundation for Knowledge Engineering and Ontologies coursework."@en .

#################################################################
# Classes
#################################################################

iiot:Asset
    a owl:Class ;
    rdfs:label "Asset"@en ;
    rdfs:comment "A physical or logical industrial entity that can be monitored, maintained, or identified in a factory knowledge graph."@en .

iiot:Equipment
    a owl:Class ;
    rdfs:subClassOf iiot:Asset ;
    rdfs:label "Equipment"@en ;
    rdfs:comment "Industrial machinery that performs a production, utility, or support function."@en .

iiot:RotatingEquipment
    a owl:Class ;
    rdfs:subClassOf iiot:Equipment ;
    rdfs:label "Rotating Equipment"@en ;
    rdfs:comment "Equipment whose operational behavior is characterized by rotating components such as shafts, bearings, or impellers."@en .

iiot:Motor
    a owl:Class ;
    rdfs:subClassOf iiot:RotatingEquipment ;
    rdfs:label "Motor"@en ;
    rdfs:comment "A rotating equipment asset that converts electrical energy into mechanical motion."@en .

iiot:Pump
    a owl:Class ;
    rdfs:subClassOf iiot:RotatingEquipment ;
    rdfs:label "Pump"@en ;
    rdfs:comment "A rotating equipment asset used to move fluids through a process system."@en .

iiot:Sensor
    a owl:Class ;
    rdfs:subClassOf iiot:Asset ;
    rdfs:label "Sensor"@en ;
    rdfs:comment "A device that observes a physical property of equipment or its operational context."@en .

iiot:VibrationSensor
    a owl:Class ;
    rdfs:subClassOf iiot:Sensor ;
    rdfs:label "Vibration Sensor"@en ;
    rdfs:comment "A sensor that measures vibration behavior of industrial equipment."@en .

iiot:TemperatureSensor
    a owl:Class ;
    rdfs:subClassOf iiot:Sensor ;
    rdfs:label "Temperature Sensor"@en ;
    rdfs:comment "A sensor that measures temperature of equipment or process environments."@en .

iiot:PressureSensor
    a owl:Class ;
    rdfs:subClassOf iiot:Sensor ;
    rdfs:label "Pressure Sensor"@en ;
    rdfs:comment "A sensor that measures pressure in a process or equipment context."@en .

iiot:Measurement
    a owl:Class ;
    rdfs:label "Measurement"@en ;
    rdfs:comment "A structured value produced through an observation, including a numeric value and optional unit."@en .

iiot:Observation
    a owl:Class ;
    rdfs:label "Observation"@en ;
    rdfs:comment "A time-stamped record generated by a sensor while monitoring equipment."@en .

iiot:Alert
    a owl:Class ;
    rdfs:label "Alert"@en ;
    rdfs:comment "A semantic notification generated when an observation indicates abnormal or risky operating behavior."@en .

iiot:ThresholdAlert
    a owl:Class ;
    rdfs:subClassOf iiot:Alert ;
    rdfs:label "Threshold Alert"@en ;
    rdfs:comment "An alert generated when a measurement exceeds a configured threshold."@en .

iiot:CriticalAlert
    a owl:Class ;
    rdfs:subClassOf iiot:ThresholdAlert ;
    rdfs:label "Critical Alert"@en ;
    rdfs:comment "A threshold alert representing a critical operating condition."@en .

iiot:FailureMode
    a owl:Class ;
    rdfs:label "Failure Mode"@en ;
    rdfs:comment "A potential or observed mechanism of equipment degradation or failure."@en .

iiot:MaintenanceEvent
    a owl:Class ;
    rdfs:label "Maintenance Event"@en ;
    rdfs:comment "A maintenance action or inspection event associated with equipment."@en .

#################################################################
# Object Properties
#################################################################

iiot:hasSensor
    a owl:ObjectProperty ;
    rdfs:domain iiot:Equipment ;
    rdfs:range iiot:Sensor ;
    owl:inverseOf iiot:monitors ;
    rdfs:label "has sensor"@en ;
    rdfs:comment "Connects equipment to an installed or associated sensor."@en .

iiot:monitors
    a owl:ObjectProperty ;
    rdfs:domain iiot:Sensor ;
    rdfs:range iiot:Equipment ;
    rdfs:label "monitors"@en ;
    rdfs:comment "Indicates which equipment is monitored by a sensor."@en .

iiot:hasObservation
    a owl:ObjectProperty ;
    rdfs:domain iiot:Sensor ;
    rdfs:range iiot:Observation ;
    rdfs:label "has observation"@en ;
    rdfs:comment "Links a sensor to an observation it produced."@en .

iiot:hasMeasurement
    a owl:ObjectProperty ;
    rdfs:domain iiot:Observation ;
    rdfs:range iiot:Measurement ;
    rdfs:label "has measurement"@en ;
    rdfs:comment "Connects an observation to its measurement value object."@en .

iiot:generatesAlert
    a owl:ObjectProperty ;
    rdfs:domain iiot:Observation ;
    rdfs:range iiot:Alert ;
    rdfs:label "generates alert"@en ;
    rdfs:comment "Indicates that an observation generated an alert."@en .

iiot:indicatesFailureMode
    a owl:ObjectProperty ;
    rdfs:domain iiot:Alert ;
    rdfs:range iiot:FailureMode ;
    rdfs:label "indicates failure mode"@en ;
    rdfs:comment "Links an alert to a suspected or known failure mode."@en .

iiot:hasMaintenanceEvent
    a owl:ObjectProperty ;
    rdfs:domain iiot:Equipment ;
    rdfs:range iiot:MaintenanceEvent ;
    rdfs:label "has maintenance event"@en ;
    rdfs:comment "Associates equipment with a maintenance action or inspection."@en .

#################################################################
# Data Properties
#################################################################

iiot:hasValue
    a owl:DatatypeProperty ;
    rdfs:domain iiot:Measurement ;
    rdfs:range xsd:decimal ;
    rdfs:label "has value"@en ;
    rdfs:comment "Numeric value of a measurement."@en .

iiot:hasTimestamp
    a owl:DatatypeProperty ;
    rdfs:range xsd:dateTime ;
    rdfs:label "has timestamp"@en ;
    rdfs:comment "Time associated with an observation, alert, or maintenance event."@en .

iiot:hasThreshold
    a owl:DatatypeProperty ;
    rdfs:domain iiot:Sensor ;
    rdfs:range xsd:decimal ;
    rdfs:label "has threshold"@en ;
    rdfs:comment "Configured threshold value for a sensor."@en .

iiot:hasUnit
    a owl:DatatypeProperty ;
    rdfs:domain iiot:Measurement ;
    rdfs:range xsd:string ;
    rdfs:label "has unit"@en ;
    rdfs:comment "Unit used for the measurement value."@en .

iiot:hasOperatingHours
    a owl:DatatypeProperty ;
    rdfs:domain iiot:Equipment ;
    rdfs:range xsd:decimal ;
    rdfs:label "has operating hours"@en ;
    rdfs:comment "Operating hours accumulated by an equipment asset."@en .

#################################################################
# Example Individuals
#################################################################

iiot:Motor-01
    a iiot:Motor ;
    rdfs:label "Motor-01"@en ;
    iiot:hasOperatingHours "1240.0"^^xsd:decimal ;
    iiot:hasSensor iiot:VibrationSensor-01 .

iiot:VibrationSensor-01
    a iiot:VibrationSensor ;
    rdfs:label "VibrationSensor-01"@en ;
    iiot:monitors iiot:Motor-01 ;
    iiot:hasThreshold "7.5"^^xsd:decimal ;
    iiot:hasObservation iiot:Observation-2026-05-06T09-15-00 .

iiot:Observation-2026-05-06T09-15-00
    a iiot:Observation ;
    rdfs:label "Vibration observation for Motor-01 at 2026-05-06 09:15:00"@en ;
    iiot:hasTimestamp "2026-05-06T09:15:00+03:00"^^xsd:dateTime ;
    iiot:hasMeasurement iiot:Measurement-Vibration-001 ;
    iiot:generatesAlert iiot:Alert-CriticalVibration-001 .

iiot:Measurement-Vibration-001
    a iiot:Measurement ;
    rdfs:label "Vibration measurement 001"@en ;
    iiot:hasValue "8.7"^^xsd:decimal ;
    iiot:hasUnit "mm/s RMS" .

iiot:Alert-CriticalVibration-001
    a iiot:CriticalAlert ;
    rdfs:label "Critical vibration alert 001"@en ;
    iiot:hasTimestamp "2026-05-06T09:15:05+03:00"^^xsd:dateTime ;
    iiot:indicatesFailureMode iiot:BearingWear .

iiot:BearingWear
    a iiot:FailureMode ;
    rdfs:label "Bearing Wear"@en ;
    rdfs:comment "A degradation mode in which bearing surfaces lose material or alignment quality, often reflected by abnormal vibration patterns."@en .
